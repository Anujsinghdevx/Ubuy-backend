{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "src/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.test.json"
      }
    ]
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "testPathIgnorePatterns": ["<rootDir>/test/smoke/", "<rootDir>/dist/"],
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/main.ts",
    "!src/**/*.module.ts",
    "!src/**/*.dto.ts",
    "!src/**/*.schema.ts"
  ],
  "coveragePathIgnorePatterns": ["<rootDir>/test/", "<rootDir>/dist/"],
  "coverageThreshold": {
    "./src/app.service.ts": {
      "branches": 70,
      "functions": 80,
      "lines": 80,
      "statements": 80
    },
    "./src/modules/auth/auth.service.ts": {
      "branches": 8,
      "functions": 25,
      "lines": 25,
      "statements": 25
    },
    "./src/modules/auth/auth.controller.ts": {
      "branches": 50,
      "functions": 35,
      "lines": 50,
      "statements": 50
    },
    "./src/modules/auctions/auctions.service.ts": {
      "branches": 4,
      "functions": 10,
      "lines": 15,
      "statements": 15
    },
    "./src/modules/bids/bids.service.ts": {
      "branches": 10,
      "functions": 10,
      "lines": 10,
      "statements": 10
    },
    "./src/modules/health/health.service.ts": {
      "branches": 50,
      "functions": 50,
      "lines": 50,
      "statements": 50
    },
    "./src/modules/notifications/notifications.controller.ts": {
      "branches": 50,
      "functions": 50,
      "lines": 50,
      "statements": 50
    },
    "./src/modules/notifications/notifications.service.ts": {
      "branches": 50,
      "functions": 50,
      "lines": 65,
      "statements": 65
    },
    "./src/modules/payments/payments.controller.ts": {
      "branches": 50,
      "functions": 50,
      "lines": 50,
      "statements": 50
    },
    "./src/modules/payments/payments.service.ts": {
      "branches": 40,
      "functions": 45,
      "lines": 45,
      "statements": 45
    }
  },
  "clearMocks": true,
  "restoreMocks": true
}
